# From @BotFather
TELEGRAM_BOT_TOKEN=
# Comma-separated Telegram numeric user IDs allowed to use the bot
TELEGRAM_ALLOWED_USERS=
# From replicate.com/account
REPLICATE_API_TOKEN=
# Face swap (image): a generative editor that takes [target, face] + an instruction.
# FACESWAP_IMAGES_KEY is the array field name (Replicate nano-banana = image_input;
# fal-style models use image_urls). Swap the model without code via these vars.
REPLICATE_IMAGE_MODEL=google/nano-banana
FACESWAP_IMAGES_KEY=image_input
FACESWAP_PROMPT=Replace the face of the person in the first image with the face of the person in the second image. Keep the first image's pose, body, clothing, lighting, background and style unchanged. Make it look natural and photorealistic.
# Video face swap (currently gated off in the bot) — inswapper-style model
REPLICATE_VIDEO_MODEL=arabyai-replicate/roop_face_swap
# Text-removal via an instruction-based image editor. Input field names are
# configurable so you can swap models without code changes:
#   flux-kontext-pro → input_image + prompt   (default, best quality)
#   qwen/qwen-image-edit → image + prompt
#   adirik/inst-inpaint → image + instruction
REPLICATE_TEXT_REMOVAL_MODEL=black-forest-labs/flux-kontext-pro
TEXT_REMOVAL_PROMPT=Remove all text, letters, captions and watermarks from the image. Keep everything else exactly the same.
REPLICATE_TEXT_REMOVAL_IMAGE_KEY=input_image
REPLICATE_TEXT_REMOVAL_PROMPT_KEY=prompt
# Guardrails
MAX_VIDEO_SECONDS=15
MAX_FILE_MB=20
# Where face library + temp files live
DATA_DIR=./data
# Free GIPHY API key from developers.giphy.com (optional; enables /gif and /meme)
GIPHY_API_KEY=
# How many GIFs /gif sends at once (default 3)
GIPHY_RESULT_COUNT=3
